# Copy to .env and fill in. All optional — the `mock` provider needs no keys.
# Free-tier, OpenAI-compatible unless noted.

# Groq (OpenAI-compatible). 1,000 requests/day free-tier cap is the binding constraint.
GROQ_API_KEY=

# Google Gemini free tier (native adapter, wired in M2).
GEMINI_API_KEY=

# Optional additional OpenAI-compatible free tiers used to spread the request budget (M2+).
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=
